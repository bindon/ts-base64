{
  "name": "@bindon/base64",
  "version": "1.0.5",
  "description": "A fast and simple base64 library for typescript",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "tsc -p tsconfig.esm.json && tsc -p tsconfig.cjs.json",
    "pretest": "npm run build",
    "test": "jest",
    "prebenchmark": "npm run build",
    "benchmark": "node dist/cjs/benchmark/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bindon/ts-base64.git"
  },
  "keywords": [
    "base64",
    "base64url",
    "nopadding",
    "wrap",
    "typescript",
    "javascript",
    "fast",
    "simple",
    "light"
  ],
  "author": "Wonbin Choi",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/bindon/ts-base64/issues",
    "email": "bindon@hanmir.com"
  },
  "homepage": "https://github.com/bindon/ts-base64#readme",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "devDependencies": {
    "@types/benchmark": "^2.1.5",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.3.0",
    "prettier": "^3.8.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  }
}
